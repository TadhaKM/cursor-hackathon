# Frontend (Vite) — base URLs for the three backend services.
# Copy to .env.local for local dev. If ANY pipeline URL is unset, the frontend
# falls back to its built-in mock pipeline (see src/api.ts).
#
# TIP: For hackathon demo without running backends, leave all three commented out.
#
# Local dev ports (each service's default):
#   repo-ingest    -> 3000   (POST /ingest)
#   repo-explainer -> 8787   (POST /explain)
#   video-renderer -> 8000   (POST /render, GET /render/:job_id)

VITE_INGEST_URL=http://localhost:3000
VITE_EXPLAIN_URL=http://localhost:8787
VITE_RENDER_URL=http://localhost:8000

# Chat — optional Gemini proxy (Vercel serverless, api/chat.ts).
# If unset, repo chat falls back to Person 2's POST /chat when VITE_EXPLAIN_URL is set.
# Locally: run `npm run dev:api` on port 3001 and point here.
# Production: https://<your-vercel-project>.vercel.app/api/chat
VITE_CHAT_URL=

# Server-only for api/chat.ts (NEVER prefix with VITE_ — do not commit real keys):
# GEMINI_API_KEY=
# GEMINI_MODEL=gemini-2.0-flash
# ALLOWED_ORIGIN=https://your-frontend.onrender.com
