# GitHub personal access token (classic or fine-grained).
# Without this you are limited to 60 requests/hour; with it, 5000/hour.
# For public repos, a token with no scopes ("public_repo" read) is enough.
GITHUB_TOKEN=

# Port the HTTP server listens on (Render sets this automatically).
PORT=3000

# In-memory cache tuning (optional).
CACHE_TTL_MS=600000
CACHE_MAX_ENTRIES=100
