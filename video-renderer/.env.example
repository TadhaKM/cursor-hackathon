# Set MOCK_VIDEO=true to skip real HeyGen calls and return instant fake
# video URLs. Lets the frontend be built/tested without burning render time.
# NOTE: real rendering requires HeyGen *API* credits on the account — without
# them, /render fails fast with MOVIO_PAYMENT_INSUFFICIENT_CREDIT.
MOCK_VIDEO=false

HEYGEN_API_KEY=
# Known-good IDs for this account (verified against /avatars and /voices).
HEYGEN_AVATAR_ID=Anna_public_3_20240108
HEYGEN_VOICE_ID=f38a635bee7a4d1f9b0a654a31d050d2

# Public URL this service is reachable at once deployed (used to build
# absolute diagram_image_url links). Defaults to http://localhost:8000.
PUBLIC_BASE_URL=http://localhost:8000
