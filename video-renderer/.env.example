# Set MOCK_VIDEO=true to skip real HeyGen calls and return instant fake
# video URLs. Lets the frontend be built/tested without burning render time.
MOCK_VIDEO=false

HEYGEN_API_KEY=
# Pick these from GET /avatars and GET /voices once HEYGEN_API_KEY is set.
HEYGEN_AVATAR_ID=
HEYGEN_VOICE_ID=

# Public URL this service is reachable at once deployed (used to build
# absolute diagram_image_url links). Defaults to http://localhost:8000.
PUBLIC_BASE_URL=http://localhost:8000
