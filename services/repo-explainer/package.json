{
  "name": "repo-explainer",
  "version": "1.0.0",
  "description": "Turns repo ingestion output into an architecture summary, a spoken narration script, and a Mermaid diagram using Google AI Studio (Gemini).",
  "type": "module",
  "main": "src/server.js",
  "scripts": {
    "start": "node src/server.js",
    "dev": "node --watch src/server.js",
    "smoke": "node scripts/smoke.js",
    "quality": "node scripts/quality-pass.js",
    "language-test": "node scripts/language-test.js",
    "history-test": "node scripts/history-test.js",
    "test": "node --test test/*.test.js"
  },
  "engines": {
    "node": ">=18"
  },
  "dependencies": {
    "cors": "^2.8.5",
    "dotenv": "^16.4.7",
    "express": "^4.21.2",
    "openai": "^4.77.0"
  }
}
