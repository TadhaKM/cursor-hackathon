{
  "name": "repo-explainer",
  "version": "1.0.0",
  "description": "Turns repo ingestion output into an architecture summary, a spoken narration script, and a Mermaid diagram using Alibaba Qwen (Model Studio).",
  "type": "module",
  "main": "src/server.js",
  "scripts": {
    "start": "node src/server.js",
    "dev": "node --watch src/server.js",
    "smoke": "node scripts/smoke.js",
    "quality": "node scripts/quality-pass.js",
    "test": "node --test"
  },
  "engines": {
    "node": ">=18"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.110.0",
    "cors": "^2.8.5",
    "dotenv": "^16.4.7",
    "express": "^4.21.2",
    "openai": "^4.77.0"
  }
}
