# Alibaba Cloud Model Studio (DashScope) API key — required.
# Get one at https://bailian.console.alibabacn.com / https://dashscope-intl.aliyuncs.com
QWEN_API_KEY=sk-your-key-here

# OpenAI-compatible base URL for Qwen. Default is the international endpoint.
# Mainland China: https://dashscope.aliyuncs.com/compatible-mode/v1
QWEN_BASE_URL=https://dashscope-intl.aliyuncs.com/compatible-mode/v1

# Model to use for all three calls (qwen-max is best quality, qwen-plus is faster/cheaper).
QWEN_MODEL=qwen-max

# Per-call timeout in milliseconds (3 sequential calls => keep individual calls tight).
QWEN_TIMEOUT_MS=30000

# Retries for transient (timeout/upstream) errors. 1 => 2 total attempts.
QWEN_MAX_RETRIES=1

# Rate-limit (HTTP 429) handling. A single /explain fires several sequential
# model calls, which trips free-tier quotas; the client honors the server's
# "retry after" hint and retries up to this many times.
QWEN_RATE_LIMIT_RETRIES=4
QWEN_RATE_LIMIT_MAX_DELAY_MS=35000

# HTTP port for the service.
PORT=8787

# --- Alternative: Google AI Studio (Gemini) ---------------------------------
# The client is a plain OpenAI-compatible call, so you can point it at Gemini
# instead of Qwen with no code change:
#   QWEN_API_KEY=<your Google AI Studio key>
#   QWEN_BASE_URL=https://generativelanguage.googleapis.com/v1beta/openai
#   QWEN_MODEL=gemini-2.5-flash-lite     # recommended: handles the large
#                                        # prompts and has the roomiest free-tier
#                                        # request quota of the flash models.
#   QWEN_TIMEOUT_MS=90000                # allow headroom for the large prompts
# Notes on free-tier quotas (per-model, per-day):
#   - gemini-2.5-flash has a very small free-tier request budget; a few /explain
#     runs will exhaust it (HTTP 429). Prefer flash-lite, or add billing.
#   - gemini-2.0-flash / -lite are often quota-blocked (limit 0) on new keys.
