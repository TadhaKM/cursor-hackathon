# Google AI Studio API key — required.
# Create one at https://aistudio.google.com/apikey
GEMINI_API_KEY=AIza-your-key-here

# OpenAI-compatible Gemini endpoint (default works for AI Studio keys).
GEMINI_BASE_URL=https://generativelanguage.googleapis.com/v1beta/openai/

# Model for all pipeline calls (gemini-2.5-flash is fast; gemini-2.5-pro for higher quality).
GEMINI_MODEL=gemini-2.5-flash

# Per-call timeout in milliseconds (3 sequential calls => keep individual calls tight).
GEMINI_TIMEOUT_MS=30000

# Retries per call (1 = two attempts total).
GEMINI_MAX_RETRIES=1

# HTTP port for the service.
PORT=8787
