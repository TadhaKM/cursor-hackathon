# ============================================================================
# LLM provider
# ============================================================================
# Two paths are supported:
#   1. Anthropic (Claude)  — recommended, reliable. Set ANTHROPIC_API_KEY.
#   2. OpenAI-compatible   — OpenRouter or Google Gemini (free tiers 429/503 a
#                            lot). Used when no Anthropic key is set.
#
# /explain auto-selects Anthropic when ANTHROPIC_API_KEY is present. Force it
# either way with EXPLAIN_PROVIDER=anthropic|openai.

# --- Anthropic (Claude) — powers /explain and /chat -------------------------
# Get a key at https://console.anthropic.com/
ANTHROPIC_API_KEY=sk-ant-...
# Model for both /explain and /chat. Sonnet is fast + reliable for both.
ANTHROPIC_MODEL=claude-sonnet-5
# Optionally use a different model just for /explain or just for /chat:
# EXPLAIN_MODEL=claude-sonnet-5
# ANTHROPIC_CHAT_MODEL=claude-sonnet-5
# EXPLAIN_PROVIDER=anthropic

# --- OpenAI-compatible fallback (OpenRouter / Gemini) -----------------------
# Only used for /explain when no Anthropic key is set, and for /chat fallback.
# OPENROUTER_API_KEY=sk-or-v1-your-key-here
# OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
# OPENROUTER_MODEL=google/gemini-2.5-flash
# Cap completion tokens (required on OpenRouter's free tier or it 402s).
OPENROUTER_MAX_TOKENS=8000
# Per-call timeout in milliseconds for /explain.
OPENROUTER_TIMEOUT_MS=90000

# Per-section narration resize adds ONE LLM call per out-of-range section.
# Off by default to conserve quota. Set true for tighter word counts.
REFINE_NARRATION=false

# --- /chat (RAG) ------------------------------------------------------------
# When no Anthropic key is set, chat falls back to OpenRouter:
# OPENROUTER_CHAT_MODEL=openrouter/free
# OPENROUTER_CHAT_FALLBACK_MODEL=
# Max tokens per chat answer, and the hard cap on how long a chat call may take.
CHAT_MAX_TOKENS=700
CHAT_TIMEOUT_MS=20000

# HTTP port for the service.
PORT=8787
