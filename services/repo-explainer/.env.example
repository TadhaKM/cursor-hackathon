# OpenRouter (OpenAI-compatible) API key — required.
# Get one at https://openrouter.ai/keys
OPENROUTER_API_KEY=sk-or-v1-your-key-here

# OpenAI-compatible base URL for OpenRouter.
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1

# Model id (OpenRouter uses provider/model). google/gemini-2.5-flash handles
# the large prompts well; see https://openrouter.ai/models for options.
OPENROUTER_MODEL=google/gemini-2.5-flash

# Cap completion tokens. Required on OpenRouter's FREE tier — without a cap the
# request asks for the model max and is rejected with a 402. Add credits at
# https://openrouter.ai/settings/credits to raise this.
OPENROUTER_MAX_TOKENS=8000

# Per-call timeout in milliseconds.
OPENROUTER_TIMEOUT_MS=90000

# Per-section narration resize adds ONE LLM call per out-of-range section.
# Off by default to conserve quota. Set true for tighter word counts.
REFINE_NARRATION=false

# HTTP port for the service.
PORT=8787
