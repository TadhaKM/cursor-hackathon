# Alibaba Cloud Model Studio (DashScope) API key — required.
# Get one at https://bailian.console.alibabacn.com / https://dashscope-intl.aliyuncs.com
QWEN_API_KEY=sk-your-key-here

# OpenAI-compatible base URL for Qwen. Default is the international endpoint.
# Mainland China: https://dashscope.aliyuncs.com/compatible-mode/v1
QWEN_BASE_URL=https://dashscope-intl.aliyuncs.com/compatible-mode/v1

# Model to use for all three calls (qwen-max is best quality, qwen-plus is faster/cheaper).
QWEN_MODEL=qwen-max

# Per-call timeout in milliseconds (3 sequential calls => keep individual calls tight).
QWEN_TIMEOUT_MS=30000

# Per-section narration resize adds ONE LLM call per out-of-range section.
# Off by default to conserve rate-limited free-tier quota (esp. Gemini's
# 20 req/min). Set true for tighter word counts if you have quota headroom.
REFINE_NARRATION=false

# HTTP port for the service.
PORT=8787

# --- Alternative: Google AI Studio (Gemini) ---------------------------------
# The client is a plain OpenAI-compatible call, so you can point it at Gemini
# instead of Qwen with no code change:
#   QWEN_API_KEY=<your Google AI Studio key>
#   QWEN_BASE_URL=https://generativelanguage.googleapis.com/v1beta/openai
#   QWEN_MODEL=gemini-2.5-flash          # handles the large prompts; ~60s/run
#   QWEN_TIMEOUT_MS=90000                # 2.5-flash "thinks", so allow headroom
# Note: gemini-2.5-flash-lite is faster but 503s on the larger architecture
# prompt on the free tier; gemini-2.0-flash may be quota-blocked (limit 0).
