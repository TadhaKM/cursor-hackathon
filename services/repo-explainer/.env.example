# Google AI Studio (Gemini) API key — required.
# Get one at https://aistudio.google.com/apikey
GEMINI_API_KEY=your-google-ai-studio-key

# OpenAI-compatible base URL for the Gemini API (the LLM client is a plain
# OpenAI-compatible call pointed here).
GEMINI_BASE_URL=https://generativelanguage.googleapis.com/v1beta/openai

# Model to use for all calls.
#   gemini-flash-latest      recommended: handles the large architecture prompt
#                            and has the roomiest free-tier request quota.
# Notes on free-tier quotas (per-model, per-day):
#   - gemini-2.5-flash has a very small free-tier request budget; a few /explain
#     runs will exhaust it (HTTP 429). Prefer flash-latest, or enable billing.
#   - gemini-2.5-flash-lite is faster but 503s on the large architecture prompt.
GEMINI_MODEL=gemini-flash-latest

# Per-call timeout in milliseconds (several sequential calls; allow headroom
# since the flash models "think" on the large prompts).
GEMINI_TIMEOUT_MS=90000

# Retries for transient (timeout/upstream) errors. 1 => 2 total attempts.
GEMINI_MAX_RETRIES=1

# Rate-limit (HTTP 429) and transient-overload (503) handling. A single /explain
# fires several sequential model calls, which trips free-tier quotas; the client
# honors the server's "retry after" hint and retries up to this many times.
GEMINI_RATE_LIMIT_RETRIES=4
GEMINI_RATE_LIMIT_MAX_DELAY_MS=35000

# HTTP port for the service.
PORT=8787
