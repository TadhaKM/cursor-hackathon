# Google AI Studio (Gemini) API key — required.
# Get one at https://aistudio.google.com/apikey
GEMINI_API_KEY=your-key-here

# OpenAI-compatible base URL for Gemini.
GEMINI_BASE_URL=https://generativelanguage.googleapis.com/v1beta/openai

# Model for all three calls. gemini-2.5-flash handles the large prompts well;
# gemini-2.5-flash-lite is faster/cheaper but can 503 on the big architecture
# prompt on the free tier.
GEMINI_MODEL=gemini-2.5-flash

# Per-call timeout in milliseconds (2.5-flash "thinks", so allow headroom).
GEMINI_TIMEOUT_MS=90000

# Per-section narration resize adds ONE LLM call per out-of-range section.
# Off by default to conserve rate-limited free-tier quota (Gemini free tier is
# ~20 requests/min). Set true for tighter word counts if you have quota.
REFINE_NARRATION=false

# HTTP port for the service.
PORT=8787
